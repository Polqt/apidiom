{
  "name": "apidiom",
  "version": "0.4.0",
  "description": "Turn any API into an MCP server in one command.",
  "type": "commonjs",
  "bin": {
    "apidiom": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "openapi",
    "ai",
    "llm",
    "api",
    "claude",
    "tool-calling"
  ],
  "homepage": "https://github.com/poyhi/apidiom",
  "repository": {
    "type": "git",
    "url": "https://github.com/poyhi/apidiom.git"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
