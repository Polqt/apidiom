---
import { flattenSidebar } from '../../../node_modules/@astrojs/starlight/utils/navigation';
import type { SidebarEntry } from '../../../node_modules/@astrojs/starlight/utils/routing/types';
import Icon from '../../../node_modules/@astrojs/starlight/user-components/Icon.astro';
import Badge from '../../../node_modules/@astrojs/starlight/user-components/Badge.astro';
import SidebarRestorePoint from '../../../node_modules/@astrojs/starlight/components/SidebarRestorePoint.astro';

interface Props {
	sublist: SidebarEntry[];
	nested?: boolean;
}

const { sublist, nested } = Astro.props;
---

<ul class:list={{ 'top-level': !nested }}>
	{
		sublist.map((entry) => (
			<li>
				{entry.type === 'link' ? (
					<a
						href={entry.href}
						aria-current={entry.isCurrent && 'page'}
						class:list={[{ large: !nested }, entry.attrs.class]}
						{...entry.attrs}
					>
						<span>{entry.label}</span>
						{entry.badge && (
							<Badge
								variant={entry.badge.variant}
								class={entry.badge.class}
								text={entry.badge.text}
							/>
						)}
					</a>
				) : (
					<details
						open={flattenSidebar(entry.entries).some((i) => i.isCurrent) || !entry.collapsed}
					>
						<summary>
							<span class="group-label">
								<span class="large">{entry.label}</span>
								{entry.badge && (
									<Badge
										variant={entry.badge.variant}
										class={entry.badge.class}
										text={entry.badge.text}
									/>
								)}
							</span>
							<Icon name="right-caret" class="caret" size="0.85rem" />
						</summary>
						<SidebarRestorePoint />
						<Astro.self sublist={entry.entries} nested />
					</details>
				)}
			</li>
		))
	}
</ul>

<style>
	ul {
		--sl-sidebar-item-padding-inline: 0.5rem;
		list-style: none;
		padding: 0;
	}

	li {
		overflow-wrap: anywhere;
	}

	ul ul li {
		margin-inline-start: var(--sl-sidebar-item-padding-inline);
		padding-inline-start: var(--sl-sidebar-item-padding-inline);
	}

	.large {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--sl-color-gray-3);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.top-level > li + li {
		margin-top: 0.75rem;
	}

	summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.35rem var(--sl-sidebar-item-padding-inline);
		line-height: 1;
		cursor: pointer;
		user-select: none;
	}
	summary::marker,
	summary::-webkit-details-marker {
		display: none;
	}

	.group-label {
		display: inline-flex;
		align-items: center;
		line-height: 1;
		margin-block-start: 0;
	}

	.group-label::before {
		content: '// ';
		color: var(--sl-color-gray-5);
		font-weight: 400;
		font-family: var(--sl-font-mono);
	}

	.caret {
		transition: transform 0.2s ease-in-out;
		flex-shrink: 0;
		color: var(--sl-color-gray-3);
	}
	:global([dir='rtl']) .caret {
		transform: rotateZ(180deg);
	}
	[open] > summary .caret {
		transform: rotateZ(90deg);
	}

	a {
		display: block;
		border-radius: 0;
		text-decoration: none;
		color: var(--sl-color-gray-3);
		padding: 0.28rem 1rem;
		font-size: 0.72rem;
		letter-spacing: 0.02em;
		line-height: 1.4;
		font-family: var(--sl-font-mono);
		transition: color 0.1s;
	}

	a:hover,
	a:focus {
		color: var(--sl-color-gray-1);
		background: transparent;
	}

	[aria-current='page'],
	[aria-current='page']:hover,
	[aria-current='page']:focus {
		font-weight: 600;
		color: var(--sl-color-white) !important;
		background: transparent !important;
		padding-left: calc(1rem - 2px);
		border-left: 2px solid var(--sl-color-gray-3);
	}
</style>
