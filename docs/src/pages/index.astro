---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/700.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Turn OpenAPI specs into standalone MCP servers and raw SDK tool schemas." />
  <title>apidiom - OpenAPI to agent tools</title>
</head>
<body>

<nav class="site-nav" aria-label="Primary navigation">
  <a class="logo" href="/" aria-label="apidiom home"><span>&gt;</span> apidiom</a>
  <div class="nav-r">
    <a href="/quickstart/">docs</a>
    <a href="https://www.npmjs.com/package/apidiom">npm</a>
    <a href="https://github.com/poyhi/apidiom">github</a>
  </div>
</nav>

<main>
  <section class="hero" data-reveal>
    <h1>
      Ship API tools<br />
      without hand wiring.
    </h1>

    <p class="sub">
      apidiom turns an OpenAPI file, URL, or built-in service name into a
      standalone MCP server or portable JSON tool schemas.
    </p>

    <div class="actions" aria-label="Primary actions">
      <a class="cmd" href="/quickstart/">
        <span>$</span> npx apidiom generate mcp stripe
      </a>
      <a class="link-btn" href="/quickstart/">quickstart -&gt;</a>
    </div>

    <div class="trust-row" aria-label="Project traits">
      <span>standalone output</span>
      <span>Node 18+</span>
      <span>MCP + SDK schemas</span>
      <span>MIT</span>
    </div>

    <div class="product-shot" aria-label="apidiom product preview">
      <div class="shot-top">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        <span class="shot-title">apidiom workspace</span>
      </div>
      <div class="shot-grid">
        <section class="shot-panel">
          <div class="panel-kicker">input</div>
          <div class="file-name">petstore.yaml</div>
          <pre><code>paths:
  /pets:
    get:
      operationId: listPets
      parameters:
        - name: limit
          in: query
          schema: &#123; type: integer &#125;</code></pre>
        </section>

        <div class="convert" aria-hidden="true">-&gt;</div>

        <section class="shot-panel output-panel">
          <div class="panel-kicker">output</div>
          <div class="tabs">
            <span class="tab active">mcp</span>
            <span class="tab">schema</span>
          </div>
          <pre><code>var _TOOLS = [&#123;
  name: "list_pets",
  description: "List pets",
  inputSchema: &#123;
    type: "object",
    properties: &#123; limit: &#123; type: "integer" &#125; &#125;
  &#125;,
  call: function(args) &#123; ... &#125;
&#125;];</code></pre>
        </section>
      </div>
      <div class="shot-status">
        <span><b>ok</b> spec parsed</span>
        <span><b>ok</b> tool names stable</span>
        <span><b>ok</b> auth stays in runtime</span>
      </div>
    </div>
  </section>

  <section class="strip" aria-label="Supported inputs" data-reveal>
    <span class="rule">// built-ins and custom specs</span>
    <div class="services">
      <span>stripe</span>
      <span>github</span>
      <span>openai</span>
      <span>petstore</span>
      <span>./openapi.yaml</span>
      <span>https://api.example.com/openapi.json</span>
    </div>
  </section>

  <section class="feature feature-a" data-reveal>
    <div class="feature-copy" data-reveal>
      <span class="section-label">MCP servers</span>
      <h2>Generate the server your agent can list and call.</h2>
      <p>
        Every selected endpoint becomes an MCP tool with the same normalized name
        used by schema export. The generated JavaScript is self-contained.
      </p>
      <a href="/mcp-server/">read MCP docs -&gt;</a>
    </div>
    <div class="feature-visual" data-reveal>
      <div class="mini-terminal">
        <div class="prompt-line">$ apidiom generate mcp ./openapi.yaml --tag pets --output pets-mcp.js</div>
        <div class="log-line">Written to pets-mcp.js</div>
        <div class="log-line muted">tools/list -> list_pets, create_pet, get_pet</div>
      </div>
    </div>
  </section>

  <section class="feature feature-b" data-reveal>
    <div class="feature-visual schema-card" data-reveal>
      <div class="schema-head">
        <span>tools.json</span>
        <span>openai</span>
      </div>
      <pre><code>[&#123;
  "type": "function",
  "function": &#123;
    "name": "list_pets",
    "parameters": &#123;
      "type": "object",
      "properties": &#123;
        "limit": &#123; "type": "integer" &#125;
      &#125;
    &#125;
  &#125;
&#125;]</code></pre>
    </div>
    <div class="feature-copy" data-reveal>
      <span class="section-label">Raw SDK schemas</span>
      <h2>Export portable tool input schemas.</h2>
      <p>
        Use <code>--format openai</code> or <code>--format anthropic</code> when
        your runtime already handles HTTP, auth, retries, and observability.
      </p>
      <a href="/quickstart/#generate-json-tool-schemas">generate schemas -&gt;</a>
    </div>
  </section>

  <section class="workflow" data-reveal>
    <span class="rule">// workflow</span>
    <div class="steps">
      <div class="step">
        <span>01</span>
        <h3>Point at a spec</h3>
        <p>Use a built-in service, local file, or URL. JSON and YAML specs are supported.</p>
      </div>
      <div class="step">
        <span>02</span>
        <h3>Trim the surface</h3>
        <p>Filter large APIs with <code>--tag</code> or <code>--include</code> before generating tools.</p>
      </div>
      <div class="step">
        <span>03</span>
        <h3>Drop into your agent</h3>
        <p>Run the MCP file, or load the JSON schema into your SDK tool registry.</p>
      </div>
    </div>
  </section>
</main>

<footer>
  <span>apidiom</span>
  <div class="footer-r">
    <a href="https://www.npmjs.com/package/apidiom">npm</a>
    <span>/</span>
    <a href="https://github.com/poyhi/apidiom">github</a>
    <span>/</span>
    <span>MIT</span>
  </div>
</footer>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const revealTargets = Array.from(document.querySelectorAll('[data-reveal]'));

  if (!reduceMotion && 'IntersectionObserver' in window) {
    document.documentElement.classList.add('has-scroll-reveal');

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    }, {
      rootMargin: '0px 0px -14% 0px',
      threshold: 0.18,
    });

    for (const target of revealTargets) observer.observe(target);
  } else {
    for (const target of revealTargets) target.classList.add('is-visible');
  }
</script>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f8f8f8;
    --bg-soft: #f3f3f3;
    --panel: #f0f0f0;
    --panel-2: #e8e8e8;
    --line: #d4d4d4;
    --line-2: #b8b8b8;
    --muted: #686868;
    --subtle: #333333;
    --text: #111111;
    --hi: #000000;
    --ok: #22775f;
    --mono: 'JetBrains Mono', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    min-width: 320px;
    background: var(--bg);
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, #d0d0d0 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.3;
    pointer-events: none;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.04), transparent 28rem),
      linear-gradient(90deg, transparent, rgba(0,0,0,0.018), transparent);
    pointer-events: none;
  }

  a { color: inherit; }

  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    background: rgba(248,248,248,0.9);
    backdrop-filter: blur(20px);
    padding: 0 2rem;
    animation: navDrop 520ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .logo {
    color: var(--hi);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .logo span { color: var(--subtle); margin-right: 0.35rem; font-weight: 400; }

  .nav-r { display: flex; align-items: center; gap: 0.35rem; }

  .nav-r a {
    color: var(--muted);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    padding: 0.35rem 0.62rem;
    border: 1px solid transparent;
    transition: color 0.12s, border-color 0.12s;
  }

  .nav-r a:hover { color: var(--hi); border-color: var(--line-2); }

  main, footer { position: relative; z-index: 1; }

  .hero {
    width: min(1160px, calc(100% - 2rem));
    margin: 0 auto;
    min-height: 100svh;
    display: grid;
    justify-items: center;
    text-align: center;
    padding: 9rem 0 6rem;
  }

  .eyebrow,
  .section-label,
  .rule {
    color: var(--muted);
    font-size: 0.63rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .eyebrow {
    border: 1px solid var(--line-2);
    background: rgba(0,0,0,0.02);
    padding: 0.34rem 0.78rem;
    margin-bottom: 1.7rem;
  }

  h1 {
    max-width: 10ch;
    color: var(--hi);
    font-size: clamp(3.1rem, 8.4vw, 7rem);
    font-weight: 700;
    line-height: 0.94;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .sub {
    max-width: 58ch;
    margin: 1.6rem auto 0;
    color: var(--subtle);
    font-size: clamp(0.84rem, 1.4vw, 1rem);
    line-height: 1.85;
  }

  .actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.25rem;
    flex-wrap: wrap;
  }

  .cmd,
  .link-btn {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 1px solid var(--line-2);
    background: transparent;
    color: var(--hi);
    padding: 0.65rem 1rem;
    cursor: pointer;
    transition: border-color 0.14s, background 0.14s, color 0.14s, transform 0.14s;
  }

  .cmd { background: rgba(0,0,0,0.035); }
  .cmd span { color: var(--muted); margin-right: 0.5rem; }
  .cmd:hover,
  .link-btn:hover { border-color: var(--subtle); background: rgba(0,0,0,0.055); }
  .cmd:active,
  .link-btn:active { transform: translateY(1px); }
  .link-btn { color: var(--subtle); }

  .trust-row {
    width: min(760px, 100%);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid var(--line);
    margin: 3rem 0 1.35rem;
    background: rgba(248,248,248,0.64);
  }

  .trust-row span {
    min-width: 0;
    padding: 0.75rem 0.5rem;
    color: var(--muted);
    font-size: 0.63rem;
    letter-spacing: 0.06em;
    border-right: 1px solid var(--line);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .trust-row span:last-child { border-right: 0; }

  .product-shot {
    width: min(1040px, 100%);
    border: 1px solid var(--line-2);
    background: linear-gradient(180deg, rgba(0,0,0,0.035), rgba(0,0,0,0.01)), var(--panel);
    box-shadow: 0 32px 90px rgba(0,0,0,0.1);
    text-align: left;
    overflow: hidden;
    position: relative;
    isolation: isolate;
  }

  .product-shot::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(110deg, transparent 0%, rgba(0,0,0,0.055) 45%, transparent 62%);
    transform: translateX(-115%);
    animation: sweep 7.5s cubic-bezier(0.16, 1, 0.3, 1) 1.2s infinite;
    pointer-events: none;
  }

  .shot-top {
    height: 42px;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-bottom: 1px solid var(--line);
    padding: 0 1rem;
    background: rgba(248,248,248,0.52);
    position: relative;
    z-index: 2;
  }

  .dot { width: 7px; height: 7px; border-radius: 999px; background: #555; }
  .dot:nth-child(1) { background: #666; }
  .dot:nth-child(2) { background: #888; }
  .dot:nth-child(3) { background: #aaa; }

  .shot-title {
    flex: 1;
    text-align: center;
    color: var(--muted);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .shot-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 56px minmax(0, 1fr);
    min-height: 350px;
    position: relative;
    z-index: 2;
  }

  .shot-panel {
    min-width: 0;
    padding: 1.2rem;
    border-right: 1px solid var(--line);
  }

  .output-panel { border-right: 0; }

  .panel-kicker {
    color: var(--muted);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .file-name {
    color: var(--hi);
    font-size: 0.78rem;
    margin-bottom: 0.8rem;
  }

  pre {
    margin: 0;
    max-width: 100%;
    overflow-x: auto;
    color: var(--subtle);
    font-family: var(--mono);
    font-size: 0.73rem;
    line-height: 1.75;
  }

  code { font-family: var(--mono); }

  .convert {
    display: grid;
    place-items: center;
    color: var(--hi);
    border-right: 1px solid var(--line);
    background: rgba(0,0,0,0.035);
  }

  .tabs {
    display: flex;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
  }

  .tab {
    color: var(--muted);
    border: 1px solid var(--line);
    padding: 0.18rem 0.5rem;
    font-size: 0.62rem;
  }

  .tab.active { color: var(--hi); border-color: var(--line-2); background: rgba(0,0,0,0.04); }

  .shot-status {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding: 0.75rem 1rem;
    background: rgba(248,248,248,0.62);
    position: relative;
    z-index: 2;
  }

  .shot-status span {
    color: var(--muted);
    font-size: 0.64rem;
  }

  .shot-status b { color: var(--ok); font-weight: 600; }

  .strip,
  .workflow {
    width: min(1040px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 0 0 7rem;
  }

  .rule {
    display: block;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
    margin-bottom: 1.2rem;
  }

  .services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .services span {
    border: 1px solid var(--line);
    background: rgba(0,0,0,0.02);
    color: var(--subtle);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    padding: 0.45rem 0.7rem;
  }

  .feature {
    width: min(1040px, calc(100% - 2rem));
    margin: 0 auto 7rem;
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
    gap: 1rem;
    align-items: stretch;
  }

  .feature-b {
    grid-template-columns: minmax(0, 1.14fr) minmax(0, 0.86fr);
  }

  .feature-copy,
  .feature-visual {
    border: 1px solid var(--line);
    background: rgba(248,248,248,0.76);
    min-width: 0;
  }

  .feature-copy {
    padding: clamp(1.4rem, 4vw, 2.4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .feature-copy h2 {
    color: var(--hi);
    font-size: clamp(1.45rem, 3vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: 0;
    margin-top: 0.8rem;
    max-width: 13ch;
  }

  .feature-copy p {
    color: var(--subtle);
    font-size: 0.82rem;
    line-height: 1.8;
    margin-top: 1.2rem;
    max-width: 54ch;
  }

  .feature-copy code {
    color: var(--hi);
    border: 1px solid var(--line);
    background: var(--panel-2);
    padding: 0.08rem 0.32rem;
    font-size: 0.78em;
  }

  .feature-copy a {
    width: fit-content;
    color: var(--subtle);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 1px solid var(--line-2);
    padding: 0.5rem 0.75rem;
    margin-top: 1.5rem;
    transition: color 0.14s, border-color 0.14s, transform 0.14s;
  }

  .feature-copy a:hover { color: var(--hi); border-color: var(--subtle); }
  .feature-copy a:active { transform: translateY(1px); }

  .feature-visual {
    padding: 1rem;
    display: grid;
    place-items: center;
    min-height: 320px;
    background:
      linear-gradient(135deg, rgba(0,0,0,0.04), transparent 38%),
      var(--bg-soft);
  }

  .mini-terminal {
    width: min(100%, 520px);
    border: 1px solid var(--line-2);
    background: #f8f8f8;
    padding: 1rem;
    box-shadow: inset 0 1px 0 rgba(0,0,0,0.04);
    transform: translateY(0);
    transition: transform 260ms cubic-bezier(0.16, 1, 0.3, 1), border-color 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feature-visual:hover .mini-terminal {
    transform: translateY(-3px);
    border-color: var(--subtle);
  }

  .prompt-line,
  .log-line {
    color: var(--subtle);
    font-size: 0.72rem;
    line-height: 1.8;
    overflow-wrap: anywhere;
  }

  .prompt-line { color: var(--hi); margin-bottom: 1rem; }
  .log-line.muted { color: var(--muted); }

  .schema-card {
    display: block;
    padding: 0;
    transform: translateY(0);
    transition: transform 260ms cubic-bezier(0.16, 1, 0.3, 1), border-color 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .schema-card:hover {
    transform: translateY(-3px);
    border-color: var(--subtle);
  }

  .schema-head {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--line);
    padding: 0.8rem 1rem;
    text-transform: uppercase;
  }

  .schema-card pre { padding: 1rem; }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border: 1px solid var(--line);
  }

  .step {
    min-width: 0;
    padding: 1.25rem;
    border-right: 1px solid var(--line);
    background: rgba(248,248,248,0.76);
  }

  .step:last-child { border-right: 0; }

  .step span {
    color: var(--muted);
    font-size: 0.64rem;
  }

  .step h3 {
    color: var(--hi);
    font-size: 0.9rem;
    margin: 0.7rem 0 0.45rem;
  }

  .step p {
    color: var(--subtle);
    font-size: 0.72rem;
    line-height: 1.75;
  }

  .step code {
    color: var(--hi);
    font-size: 0.9em;
  }

  footer {
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    padding: 1rem 2rem;
  }

  .footer-r {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer-r a { color: var(--muted); text-decoration: none; }
  .footer-r a:hover { color: var(--hi); }

  @keyframes navDrop {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes riseIn {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes sweep {
    0%, 45% { transform: translateX(-115%); opacity: 0; }
    55% { opacity: 1; }
    100% { transform: translateX(115%); opacity: 0; }
  }

  @keyframes softPulse {
    0%, 100% { opacity: 0.72; }
    50% { opacity: 1; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .has-scroll-reveal [data-reveal] {
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity 720ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 720ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: opacity, transform;
    }

    .has-scroll-reveal [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
      will-change: auto;
    }

    .has-scroll-reveal .feature-copy[data-reveal] {
      transition-delay: 90ms;
    }

    .has-scroll-reveal .feature-visual[data-reveal] {
      transition-delay: 170ms;
    }

    .eyebrow,
    h1,
    .sub,
    .actions,
    .trust-row,
    .product-shot {
      animation: riseIn 680ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

