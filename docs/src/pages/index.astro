---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/700.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Generate type-safe Python API clients from messy docs that have no OpenAPI spec." />
  <title>apidiom - messy docs, idiomatic client</title>
</head>
<body>

<nav>
  <div class="logo"><span class="prompt">&gt;</span> apidiom</div>
  <div class="nav-r">
    <a href="/quickstart/">docs</a>
    <a href="https://github.com/Polqt/apidiom">github</a>
  </div>
</nav>

<section class="hero">
  <h1>
    <span class="h1-line1">messy docs.</span>
    <span class="h1-line2">clean client.</span>
  </h1>

  <p class="sub">
    No OpenAPI spec? apidiom extracts one from raw HTML,<br />
    prose, or anything in between. Marks what it can't prove.<br />
    Delegates generation. Ships <code>x-apidiom-unknown</code>, never assumptions.
  </p>

  <div class="ctas">
    <button class="cta-p" onclick="navigator.clipboard?.writeText('pip install apidiom')">
      [ &thinsp;pip install apidiom&thinsp; ]
    </button>
    <a href="/quickstart/" class="cta-g">read the docs -&gt;</a>
  </div>

  <div class="term-wrap">
    <div class="terminal">
      <div class="term-shine"></div>
      <div class="term-scan"></div>
      <div class="term-bar">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="term-title">apidiom - docs to client</span>
      </div>

      <div class="term-body">
        <!-- INPUT PANE -->
        <div class="pane">
          <div class="ln" aria-hidden="true">
            <span>1</span><span>2</span><span>3</span><span>4</span>
            <span>5</span><span>6</span><span>7</span><span>8</span>
            <span>9</span><span>10</span><span>11</span><span>12</span>
          </div>
          <div class="pane-code">
            <span class="plabel">// stripe.com/docs/api - raw html</span>
            <div class="noise">
              <span class="t">&lt;section</span> <span class="a">id=</span><span class="v">"charges"</span><span class="t">&gt;</span><br />
              &nbsp;<span class="t">&lt;h2&gt;</span><span class="tx">Charges</span><span class="t">&lt;/h2&gt;</span><br />
              &nbsp;<span class="t">&lt;p&gt;</span><span class="tx">Create a charge to</span><span class="t">&lt;/p&gt;</span><br />
              &nbsp;<span class="t">&lt;dl&gt;</span><br />
              &nbsp;&nbsp;<span class="t">&lt;dt&gt;&lt;code&gt;</span><span class="tx">amount</span><span class="t">&lt;/code&gt;&lt;/dt&gt;</span><br />
              &nbsp;&nbsp;<span class="t">&lt;dd&gt;</span><span class="tx">integer, required</span><span class="t">&lt;/dd&gt;</span><br />
              &nbsp;&nbsp;<span class="t">&lt;dt&gt;&lt;code&gt;</span><span class="tx">currency</span><span class="t">&lt;/code&gt;&lt;/dt&gt;</span><br />
              &nbsp;&nbsp;<span class="t">&lt;dd&gt;</span><span class="tx">string, required</span><span class="t">&lt;/dd&gt;</span><br />
              &nbsp;&nbsp;<span class="t">&lt;dt&gt;&lt;code&gt;</span><span class="tx">metadata</span><span class="t">&lt;/code&gt;&lt;/dt&gt;</span><br />
              &nbsp;&nbsp;<span class="t">&lt;dd&gt;</span><span class="c">&lt;!-- no type info --&gt;</span><span class="t">&lt;/dd&gt;</span><br />
              &nbsp;<span class="t">&lt;/dl&gt;</span><br />
              <span class="c">&lt;!-- 138 more lines --&gt;</span>
            </div>
          </div>
        </div>

        <!-- ARROW -->
        <div class="arrow-mid" aria-hidden="true">
          <span>-</span>
          <span class="a-main">-&gt;</span>
          <span>-</span>
        </div>

        <!-- OUTPUT PANE -->
        <div class="pane">
          <div class="ln" aria-hidden="true">
            <span>1</span><span>2</span><span>3</span><span>4</span>
            <span class="active">5</span><span class="active">6</span>
            <span class="active">7</span><span class="active">8</span>
            <span class="active">9</span><span>10</span><span>11</span><span>12</span>
          </div>
          <div class="pane-code">
            <span class="plabel">// charges.py - generated</span>
            <div class="code">
              <span class="im">import</span> httpx<br />
              <span class="im">from</span> typing <span class="im">import</span> Any<br />
              <br />
              <span class="kw">class</span> <span class="cl">StripeClient</span>:<br />
              &nbsp;&nbsp;<span class="kw">def</span> <span class="fn">create_charge</span>(<br />
              &nbsp;&nbsp;&nbsp;&nbsp;self,<br />
              &nbsp;&nbsp;&nbsp;&nbsp;amount: <span class="ty">int</span>,<br />
              &nbsp;&nbsp;&nbsp;&nbsp;currency: <span class="ty">str</span>,<br />
              &nbsp;&nbsp;&nbsp;&nbsp;<span class="cm"># UNVERIFIED: metadata</span><br />
              &nbsp;&nbsp;&nbsp;&nbsp;metadata: <span class="ty">Any</span> = <span class="num">None</span>,<br />
              &nbsp;&nbsp;) -&gt; <span class="cl">Charge</span>:<br />
              &nbsp;&nbsp;&nbsp;&nbsp;...<span class="cur"></span>
            </div>
          </div>
        </div>
      </div>

      <div class="term-footer">
        <span class="tf-item"><span class="ok">ok</span> 12 endpoints extracted</span>
        <span class="tf-sep">/</span>
        <span class="tf-item"><span class="warn">warn</span> 3 unverified fields</span>
        <span class="tf-sep">/</span>
        <span class="tf-item"><span class="ok">ok</span> spec validated</span>
      </div>
    </div>
  </div>
</section>

<div class="section">
  <div class="rule">// how it works</div>

  <div class="steps">
    <div class="step">
      <div class="step-n">01.</div>
      <div class="step-body">
        <div class="step-title">point at any docs</div>
        <div class="step-desc">
          URL, file, or raw text. HTML, Markdown, Postman, or an existing
          OpenAPI file - apidiom detects which automatically.
        </div>
      </div>
    </div>
    <div class="step">
      <div class="step-n">02.</div>
      <div class="step-body">
        <div class="step-title">spec extracted &amp; validated</div>
        <div class="step-desc">
          LLM pulls structure from prose. Validator signs off. Ambiguous
          fields get <code>UNVERIFIED:</code> markers - never a silent guess,
          always a flag.
        </div>
      </div>
    </div>
    <div class="step">
      <div class="step-n">03.</div>
      <div class="step-body">
        <div class="step-title">idiomatic client in your repo</div>
        <div class="step-desc">
          Type-safe Python + httpx. Generated by battle-tested tools.
          Nothing reinvented here.
        </div>
      </div>
    </div>
  </div>

</div>

<footer>
  <span>apidiom</span>
  <span>MIT</span>
</footer>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:      #000000;
    --bg-2:    #0a0a0a;
    --bg-3:    #111111;
    --bg-4:    #181818;
    --border:  #1a1a1a;
    --border-2:#252525;
    --border-3:#333333;
    --muted:   #777777;
    --subtle:  #b0b0b0;
    --text:    #d8d8d8;
    --accent:  #aaaaaa;
    --accent-2:#cccccc;
    --hi:      #ffffff;
    --mono:    'JetBrains Mono', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image: radial-gradient(circle, #1a1a1a 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.6;
    pointer-events: none;
  }

  body::after {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(255,255,255,0.025) 0%, transparent 100%),
      radial-gradient(ellipse 60% 40% at 50% 110%, rgba(255,255,255,0.01) 0%, transparent 100%);
    pointer-events: none;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 44px;
    border-bottom: 1px solid var(--border);
    background: rgba(9,8,7,0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
  }
  .prompt { color: var(--subtle); margin-right: 0.2rem; }
  .logo { color: var(--hi); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.03em; }
  .nav-r { display: flex; align-items: center; gap: 0.05rem; }
  .nav-r a {
    color: var(--subtle); font-size: 0.68rem; text-decoration: none;
    padding: 0.22rem 0.65rem; letter-spacing: 0.05em;
    border: 1px solid transparent;
    transition: color 0.1s, border-color 0.1s;
  }
  .nav-r a:hover { color: var(--hi); }

  /* HERO */
  .hero {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 8rem 1.5rem 6rem;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }
  .h1-line1 {
    display: block;
    color: var(--hi);
  }
  .h1-line2 {
    display: block;
    color: var(--subtle);
  }

  .sub {
    color: var(--text); font-size: 0.78rem;
    max-width: 38ch; line-height: 1.85;
    margin-bottom: 2.5rem; margin-left: auto; margin-right: auto;
  }
  .sub code { color: var(--accent); font-size: 0.72rem; font-family: var(--mono); }

  .ctas {
    display: flex; gap: 0.65rem;
    align-items: center; justify-content: center;
    margin-bottom: 4rem; flex-wrap: wrap;
  }
  .cta-p {
    border: 1px solid var(--border-3);
    color: var(--hi); background: transparent;
    padding: 0.52rem 1.3rem; font-family: var(--mono);
    font-size: 0.7rem; letter-spacing: 0.07em; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .cta-p:hover { border-color: var(--subtle); background: rgba(255,255,255,0.03); }
  .cta-g {
    color: var(--subtle); background: none; border: 1px solid transparent;
    padding: 0.52rem 0.9rem; font-family: var(--mono); font-size: 0.7rem;
    letter-spacing: 0.05em; text-decoration: none;
    transition: color 0.12s, border-color 0.12s;
  }
  .cta-g:hover { color: var(--hi); border-color: var(--border-3); }

  /* TERMINAL */
  .term-wrap {
    width: 100%; max-width: 680px; position: relative;
  }
  .term-wrap::before {
    content: '';
    position: absolute; top: -40px; left: 50%; transform: translateX(-50%);
    width: 300px; height: 80px;
    background: radial-gradient(ellipse, rgba(255,255,255,0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .terminal {
    border: 1px solid var(--border-3);
    background: var(--bg-2);
    position: relative;
    box-shadow:
      0 0 0 1px var(--border),
      0 24px 80px rgba(0,0,0,0.7),
      inset 0 1px 0 rgba(255,255,255,0.02);
    overflow: hidden;
  }
  .term-shine {
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg,
      transparent 0%, var(--border-3) 20%,
      var(--subtle) 50%,
      var(--border-3) 80%, transparent 100%);
    opacity: 0.5;
  }
  @keyframes scan {
    0%   { top: 0; opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 0.3; }
    100% { top: 100%; opacity: 0; }
  }
  .term-scan {
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(transparent, rgba(255,255,255,0.06), transparent);
    animation: scan 6s ease-in-out infinite;
    pointer-events: none; z-index: 10;
  }
  .term-bar {
    display: flex; align-items: center; gap: 0.35rem;
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--border);
    background: rgba(9,8,7,0.6);
    user-select: none;
  }
  .d { width: 6px; height: 6px; border-radius: 50%; }
  .d.r { background: #ff5f57; }
  .d.y { background: #ffbd2e; }
  .d.g { background: #28c840; }
  .term-title { flex: 1; text-align: center; color: var(--subtle); font-size: 0.6rem; letter-spacing: 0.1em; }

  .term-body {
    display: grid;
    grid-template-columns: 1fr 36px 1fr;
    min-height: 200px;
  }
  .pane { display: flex; overflow: hidden; }
  .ln {
    padding: 1rem 0;
    display: flex; flex-direction: column;
    min-width: 2rem;
    border-right: 1px solid var(--border);
    background: rgba(0,0,0,0.15);
    user-select: none;
  }
  .ln span {
    display: block; text-align: right;
    padding: 0 0.4rem;
    font-size: 0.62rem; line-height: 1.75;
    color: var(--border-3);
  }
  .ln span.active { color: var(--muted); }
  .pane-code { padding: 1rem 0.9rem; flex: 1; font-size: 0.74rem; line-height: 1.75; }
  .plabel {
    font-size: 0.56rem; letter-spacing: 0.14em;
    color: var(--subtle); margin-bottom: 0.55rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem; display: block;
  }

  .noise { color: var(--subtle); }
  .noise .t  { color: #6f6f6f; }
  .noise .a  { color: #909090; }
  .noise .v  { color: var(--accent-2); }
  .noise .tx { color: var(--text); }
  .noise .c  { color: #777777; }

  .arrow-mid {
    display: flex; align-items: center; justify-content: center;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    flex-direction: column; gap: 2px;
  }
  .arrow-mid span { color: var(--muted); font-size: 0.6rem; line-height: 1; }
  .arrow-mid .a-main { color: var(--hi); font-size: 0.8rem; }

  .code .kw  { color: var(--subtle); }
  .code .cl  { color: var(--hi); font-weight: 600; }
  .code .fn  { color: var(--accent-2); }
  .code .ty  { color: var(--subtle); }
  .code .cm  { color: var(--accent); font-style: italic; }
  .code .im  { color: var(--subtle); }
  .code .num { color: var(--subtle); }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .cur {
    display: inline-block; width: 6px; height: 0.85em;
    background: var(--accent); vertical-align: middle;
    animation: blink 1.1s step-end infinite;
    margin-left: 1px; opacity: 0.75;
  }

  .term-footer {
    border-top: 1px solid var(--border);
    padding: 0.45rem 0.85rem;
    display: flex; gap: 1.5rem; align-items: center;
    background: rgba(9,8,7,0.5);
  }
  .tf-item { font-size: 0.6rem; color: var(--subtle); display: flex; gap: 0.4rem; align-items: center; }
  .tf-item .ok   { color: #4a9; }
  .tf-item .warn { color: var(--accent); }
  .tf-sep { color: var(--border-2); }

  /* HOW IT WORKS */
  .section {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    align-items: center; padding: 0 1.5rem 6rem;
  }
  .rule {
    width: 100%; max-width: 680px;
    display: flex; align-items: center; gap: 1rem;
    color: var(--subtle); font-size: 0.58rem;
    letter-spacing: 0.14em; margin: 5rem 0 3rem;
  }
  .rule::before, .rule::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  .steps {
    width: 100%; max-width: 520px;
    border: 1px solid var(--border); background: var(--bg-2);
  }
  .step {
    display: grid; grid-template-columns: 3.5rem 1fr;
    border-bottom: 1px solid var(--border);
    align-items: stretch;
  }
  .step:last-child { border-bottom: none; }
  .step-n {
    display: flex; align-items: flex-start; justify-content: center;
    padding: 1rem 0.75rem;
    border-right: 1px solid var(--border);
    color: var(--border-3); font-size: 0.62rem;
    letter-spacing: 0.04em;
    background: rgba(0,0,0,0.15);
  }
  .step-body { padding: 0.9rem 1rem; }
  .step-title { color: var(--hi); font-size: 0.76rem; font-weight: 600; margin-bottom: 0.3rem; }
  .step-desc { color: var(--text); font-size: 0.68rem; line-height: 1.7; }
  .step-desc code { color: var(--accent); font-size: 0.65rem; font-family: var(--mono); }

  /* FOOTER */
  footer {
    position: relative; z-index: 1;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2rem;
    color: var(--subtle); font-size: 0.6rem; letter-spacing: 0.07em;
  }

  /* LIGHT MODE */
  @media (prefers-color-scheme: light) {
    :root {
      --bg:      #f8f8f8;
      --bg-2:    #f0f0f0;
      --bg-3:    #e8e8e8;
      --bg-4:    #e0e0e0;
      --border:  #d0d0d0;
      --border-2:#c0c0c0;
      --border-3:#aaaaaa;
      --muted:   #888888;
      --subtle:  #444444;
      --text:    #111111;
      --accent:  #555555;
      --accent-2:#333333;
      --hi:      #000000;
    }
    body::before { opacity: 0.25; background-image: radial-gradient(circle, #d8d8d8 1px, transparent 1px); }
    .terminal {
      box-shadow: 0 0 0 1px var(--border), 0 16px 56px rgba(0,0,0,0.08);
    }
    .term-wrap::before {
      background: radial-gradient(ellipse, rgba(0,0,0,0.04) 0%, transparent 70%);
    }
    body::after {
      background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(0,0,0,0.02) 0%, transparent 100%);
    }
    nav { background: rgba(248,248,248,0.92); }
  }
</style>
